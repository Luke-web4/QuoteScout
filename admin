<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>QuoteScout Admin Login</title>

<link rel="stylesheet" href="admin.css">

</head>


<body>


<div class="login-page">


    <div class="login-card">


        <div class="logo">
            <span>Quote</span>Scout
        </div>


        <h1>
            Owner Login
        </h1>


        <p>
            Access the QuoteScout business dashboard.
        </p>



        <form id="loginForm">


            <label>
                Email
            </label>

            <input 
            type="email"
            id="email"
            placeholder="Enter owner email"
            required>



            <label>
                Password
            </label>

            <input
            type="password"
            id="password"
            placeholder="Enter password"
            required>



            <button type="submit">
                Login
            </button>


            <p id="errorMessage"></p>


        </form>


    </div>


</div>



<script src="admin.js"></script>


</body>

</html>
